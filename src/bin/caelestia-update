#!/usr/bin/env bash
export PATH="$HOME/.local/bin:$PATH"

set -uo pipefail

die()  { echo "[FATAL] $*" >&2; exit 1; }
info() { echo "[INFO]  $*"; }
ok()   { echo "[OK]    $*"; }
warn() { echo "[WARN]  $*"; }

run_stage() {
    local timeout_seconds="$1"
    shift

    if command -v timeout >/dev/null 2>&1; then
        timeout --foreground "$timeout_seconds" "$@"
    else
        "$@"
    fi
}

BRANCH="${1:-main}"
TARGET_REF="${2:-}"
if [ "$BRANCH" != "main" ] && [ "$BRANCH" != "dev" ]; then
    echo "Warning: Branch '$BRANCH' is not allowed. Falling back to 'main'."
    BRANCH="main"
fi
if ! git ls-remote --exit-code --heads https://github.com/KhanhNguyen1603/Kde-caelestia.git "$BRANCH" >/dev/null 2>&1; then
    echo "Warning: Branch '$BRANCH' does not exist on remote. Falling back to 'main'."
    BRANCH="main"
fi

if [ -n "$TARGET_REF" ]; then
    if git ls-remote --exit-code --tags https://github.com/KhanhNguyen1603/Kde-caelestia.git "$TARGET_REF" >/dev/null 2>&1; then
        TARGET_KIND="tag"
    elif [ "$BRANCH" = "dev" ] && [[ "$TARGET_REF" =~ ^[0-9a-f]{7,40}$ ]]; then
        # Dev branch supports installing/reverting to a specific commit from the
        # timeline, not just tagged releases.
        TARGET_KIND="commit"
    else
        echo "Warning: Version tag '$TARGET_REF' not found on remote. Ignoring target and using branch head."
        TARGET_REF=""
    fi
fi
UPD_DIR="$HOME/.config/caelestia-update"

echo "---------------------------------------------"
if [ -n "$TARGET_REF" ]; then
    echo "  Caelestia Update (Branch: $BRANCH, Target: $TARGET_REF)"
else
    echo "  Caelestia Update (Branch: $BRANCH)"
fi
echo "---------------------------------------------"

# --- Pre-flight Dependency Checks ---
for cmd in git cmake make; do
    if ! command -v "$cmd" &> /dev/null; then
        die "Required command '$cmd' is missing. Please install it first."
    fi
done

# --- Robust Privilege Escalation Wrapper ---
mkdir -p "$UPD_DIR/bin"
cat << 'EOF' > "$UPD_DIR/bin/sudo"
#!/usr/bin/env bash
if [ "$EUID" -eq 0 ]; then
    "$@"
elif [ -t 1 ]; then
    /usr/bin/sudo "$@"
elif command -v ksshaskpass &> /dev/null; then
    SUDO_ASKPASS=$(command -v ksshaskpass) /usr/bin/sudo -A "$@"
elif command -v pkexec &> /dev/null; then
    pkexec "$@"
else
    echo "Cannot elevate privileges. Please install ksshaskpass, pkexec, or run from a terminal." >&2
    exit 1
fi
EOF
chmod +x "$UPD_DIR/bin/sudo"
export PATH="$UPD_DIR/bin:$PATH"

# --- Prime privilege escalation once, then keep it alive ---
# Several steps below need root (system package update, the shell install
# step). Authenticate once up front and refresh the cached credential in the
# background so later sudo calls (which can happen well after the initial
# prompt, e.g. after a long shell build) reuse it instead of prompting again.
if [ "$EUID" -ne 0 ] && { [ -t 1 ] || command -v ksshaskpass &> /dev/null; }; then
    info "Requesting administrator privileges (used for system update and installing the shell)..."
    "$UPD_DIR/bin/sudo" -v || die "Failed to obtain administrator privileges."
    (
        while kill -0 "$$" 2>/dev/null; do
            sleep 60
            sudo -n true 2>/dev/null
        done
    ) &
    SUDO_KEEPALIVE_PID=$!
    trap '[ -n "${SUDO_KEEPALIVE_PID:-}" ] && kill "$SUDO_KEEPALIVE_PID" 2>/dev/null || true' EXIT
fi

# 1. Fetch from GitHub
echo "PROGRESS: 1/5: Fetching updates from GitHub..."
info "Checking for local repository cache..."

# --- Safe Backup Directory outside of the git repo ---
export BACKUP_DIR="$UPD_DIR/backups/$(date +%Y%m%d_%H%M%S)"
mkdir -p "$BACKUP_DIR"

if [[ ! -d "$UPD_DIR/repo/.git" ]]; then
    mkdir -p "$UPD_DIR/repo"
    cd "$UPD_DIR/repo"
    git init -q
    git remote add origin https://github.com/KhanhNguyen1603/Kde-caelestia.git
else
    cd "$UPD_DIR/repo"
    git reset --hard -q HEAD || die "Failed to reset repository state"
    git clean -fdx -q
    git remote set-url origin https://github.com/KhanhNguyen1603/Kde-caelestia.git
fi

# Always enforce sparse-checkout rules
git config core.sparseCheckout true
echo "shell/" > .git/info/sparse-checkout
echo "src/" >> .git/info/sparse-checkout
echo "scripts/" >> .git/info/sparse-checkout
echo ".github/version.env" >> .git/info/sparse-checkout
echo ".gitmodules" >> .git/info/sparse-checkout

# Safer fetch and reset instead of pull
if [ -n "$TARGET_REF" ] && [ "${TARGET_KIND:-}" = "commit" ]; then
    # Arbitrary commit target: the local clone is normally shallow (depth 1), so
    # pull enough history to cover the commit timeline shown in the UI
    # (UpdateChecker fetches up to 150 commits) rather than trying to unshallow.
    git fetch -q --depth=200 origin "$BRANCH" || die "Failed to fetch repository"
    if git cat-file -e "$TARGET_REF^{commit}" 2>/dev/null; then
        git reset --hard -q "$TARGET_REF" || die "Failed to apply commit $TARGET_REF"
    else
        warn "Commit '$TARGET_REF' not found on '$BRANCH'; falling back to branch head."
        git reset --hard -q origin/"$BRANCH" || die "Failed to apply updates"
    fi
elif [ -n "$TARGET_REF" ]; then
    git fetch -q --depth 1 origin "refs/tags/$TARGET_REF:refs/tags/$TARGET_REF" || die "Failed to fetch version tag"
    git reset --hard -q "$TARGET_REF" || die "Failed to apply version $TARGET_REF"
else
    git fetch -q --depth 1 origin "$BRANCH" || die "Failed to fetch repository"
    git reset --hard -q origin/"$BRANCH" || die "Failed to apply updates"
fi

# Initialize submodules
if [[ -f "$UPD_DIR/repo/.gitmodules" ]]; then
    info "Initializing all submodule..."
    git submodule sync --recursive >/dev/null 2>&1 || true
    git submodule update --init --recursive --force >/dev/null 2>&1 || die "Failed to initialize all submodules"
fi

[[ -f "$UPD_DIR/repo/src/dots/starship.toml" ]] || die "Missing src/dots content after update"

# 2. System update via Polkit
echo "PROGRESS: 2/5: Running system update..."
echo
echo "---------------------------------------------"
echo "  Step 1 - System Updates"
echo "---------------------------------------------"
if command -v pacman >/dev/null; then
    info "Running system update via pacman..."
    sudo pacman -Syu --noconfirm || warn "System update was canceled or failed. Continuing with non-sudo parts..."
elif command -v dnf >/dev/null; then
    info "Running system update via dnf..."
    sudo dnf upgrade --refresh -y || warn "System update was canceled or failed. Continuing with non-sudo parts..."
fi

# 3. Build script now handles GUI privilege escalation natively.
info "Executing build scripts (GUI prompts will appear if required)..."

export BUNDLE_DIR="$UPD_DIR/repo"

# 4. Deploy Configs
echo "PROGRESS: 3/5: Deploying configuration files..."
echo
echo "---------------------------------------------"
echo "  Step 2 - Deploy Configs"
echo "---------------------------------------------"
if [[ "${CAELESTIA_SKIP_DEPLOY:-0}" == "1" ]]; then
    info "Skipping deploy-configs per user settings."
else
    run_stage 900 bash "$UPD_DIR/repo/scripts/03-deploy-configs.sh" || die "Config deployment failed or timed out."
fi
echo "PROGRESS: 3/5: Configuration files deployed."

# 5. Build Shell
echo "PROGRESS: 4/5: Building Caelestia Shell UI..."
echo
echo "---------------------------------------------"
echo "  Step 3 - Build Caelestia Shell UI"
echo "---------------------------------------------"
if [[ "${CAELESTIA_SKIP_BUILD:-0}" == "1" ]]; then
    info "Skipping build-shell per user settings."
else
    run_stage 3600 bash "$UPD_DIR/repo/scripts/08-build-shell.sh" || die "Shell build failed or timed out."

    # Fail fast if QML module install is incomplete, otherwise shell startup fails
    # with 'module "Caelestia.Config" is not installed'.
    QML_BASE="$HOME/.local/lib/qt6/qml"
    CONFIG_MODULE_DIR="$QML_BASE/Caelestia/Config"
    if [[ ! -f "$CONFIG_MODULE_DIR/qmldir" ]]; then
        die "Installed QML module metadata missing at $CONFIG_MODULE_DIR/qmldir"
    fi

    shopt -s nullglob
    CONFIG_PLUGIN_FILES=("$CONFIG_MODULE_DIR"/*.so)
    shopt -u nullglob
    if [[ ${#CONFIG_PLUGIN_FILES[@]} -eq 0 ]]; then
        die "Installed Caelestia.Config plugin library missing in $CONFIG_MODULE_DIR"
    fi
fi

# 6. Save current commit hash
if [ -d "$UPD_DIR/repo/.git" ]; then
    COMMIT_HASH=$(git rev-parse HEAD)
    mkdir -p ~/.config/quickshell/caelestia
    echo "$COMMIT_HASH" > ~/.config/quickshell/caelestia/.current_commit

    # Persist installed version from the checked-out commit, even when sparse checkout omits files.
    git show HEAD:.github/version.env > ~/.config/quickshell/caelestia/.current_version 2>/dev/null || true

    info "Saved commit hash: $COMMIT_HASH"
fi

echo "PROGRESS: done: Update completed successfully"
echo
echo "---------------------------------------------"
echo "  Update Completed Successfully!"
echo "---------------------------------------------"
